{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ES2022",
    "moduleResolution": "bundler",
    "outDir": "./dist/web-ui",
    "rootDir": "./src/web-ui",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false,
    "types": []
  },
  "include": ["src/web-ui/app.ts", "src/web-ui/setup-api.ts"],
  "exclude": ["node_modules", "dist", "coverage", "tests", "src/web-ui/static-assets.ts"]
}
